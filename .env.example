# Copy to .env (which is gitignored) and fill in. NEVER commit real values.
# Use a NEW Gmail app password — the one previously committed in
# configs/alerts.yaml must be revoked at myaccount.google.com.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your.email@gmail.com
SMTP_PASSWORD=your-new-app-password
SMTP_FROM_NAME=Momentum Routine
DIGEST_TO=your.email@gmail.com

# Optional overrides
# ROUTINE_CAPITAL=500000
# ROUTINE_RISK_PCT=1.0
# PARQUET_ROOT=D:\WORK\NEW_STOCK_DASHBOARD\momentum-dashboard\backend\parquet
